        "destination": "/api/static/video/:path*",
        "regex": "^/video(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
      },
      {
        "source": "/pic/:path*",
        "destination": "/api/static/pic/:path*",
        "regex": "^/pic(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
      }
    ],
    "fallback": []
  },
